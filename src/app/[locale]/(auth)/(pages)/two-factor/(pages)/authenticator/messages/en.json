{
  "authenticator": {
    "handlers": {
      "submit": {
        "error": {
          "generic": "An unexpected error occurred. Please try again."
        },
        "success": "Authenticator code verified successfully."
      }
    },
    "metadata": {
      "description": "Verify your identity using the code from your authenticator app.",
      "title": "Authenticator App Verification"
    },
    "page": {
      "card": {
        "header": {
          "description": "Enter the code generated by your authenticator app.",
          "title": "Authenticator App Verification"
        },
        "content": {
          "form": {
            "code": {
              "label": "Authenticator code"
            },
            "trustDevice": {
              "label": "Trust this device for 30 days"
            },
            "submitButton": {
              "label": "Verify"
            }
          }
        },
        "footer": {
          "twoFactorLink": {
            "label": "Choose a different two-factor method"
          }
        }
      }
    },
    "schemas": {
      "totp": {
        "code": {
          "invalid": "The authenticator code is invalid.",
          "required": "The authenticator code is required."
        }
      }
    }
  }
}
